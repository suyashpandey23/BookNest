

@* hero section *@
<section class="position-relative overflow-hidden" style="background: #191414;">
    <div class="position-absolute top-0 end-0 bottom-0 d-none d-lg-block" style="width: 45%; background: linear-gradient(160deg, #1DB954, #17A34A); clip-path: polygon(15% 0, 100% 0, 100% 100%, 0% 100%);"></div>
    <div class="container position-relative py-5" style="z-index: 2;">
        <div class="row align-items-center g-5">
            <div class="col-lg-6 text-center text-lg-start">
                <p class="text-uppercase small fw-semibold mb-3" style="color: #1DB954; letter-spacing: 0.25em; font-size: 0.75rem;">
                    <i class="bi bi-star me-1"></i> Editor's Pick &mdash; January 2025
                </p>
                <h1 class="display-4 fw-bold text-white lh-sm mb-4">
                    Stories that  stay <br class="d-none d-sm-block" />
                    with you <span style="color: #1DB954;">forever.</span>
                </h1>
                <p class="lead mb-4" style="color: #94a3b8; max-width: 500px;">
                    Curated collections, bestselling authors, and hidden gems &mdash; all in one place. Start your next chapter today.
                </p>
                <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center justify-content-lg-start mb-5">
                    <a href="#catalog" class="btn btn-lg btn-accent fw-bold rounded-pill px-4">
                        Explore the Collection <i class="bi bi-arrow-right ms-2"></i>
                    </a>
                    <a href="#catalog" class="btn btn-lg btn-ghost-light rounded-pill px-4">
                        <i class="bi bi-compass me-1"></i> Browse by Category
                    </a>
                </div>
                <div class="row g-4 text-center text-lg-start" style="max-width: 420px;">
                    <div class="col-4">
                        <!-- TODO: Display total book count here -->
                        <p class="fs-4 fw-bold text-white mb-0">50+</p>
                        <p class="text-uppercase mb-0" style="font-size: 0.65rem; color: #64748b; letter-spacing: 0.1em;">Book Titles</p>
                    </div>
                    <div class="col-4 border-start" style="border-color: rgba(255,255,255,0.1) !important;">
                        <!-- TODO: Display distinct category count here -->
                        <p class="fs-4 fw-bold text-white mb-0">12</p>
                        <p class="text-uppercase mb-0" style="font-size: 0.65rem; color: #64748b; letter-spacing: 0.1em;">Categories</p>
                    </div>
                    <div class="col-4 border-start" style="border-color: rgba(255,255,255,0.1) !important;">
                        <p class="fs-4 fw-bold text-white mb-0">4.9 <i class="bi bi-star-fill small" style="color: #1DB954;"></i></p>
                        <p class="text-uppercase mb-0" style="font-size: 0.65rem; color: #64748b; letter-spacing: 0.1em;">Avg Rating</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 d-none d-lg-block" style="z-index: 2;">
                <!-- TODO: Display featured books here with dynamic data -->
                <div class="position-relative d-flex align-items-center justify-content-center" style="height: 460px;">
                    <!-- Back-left book -->
                    <div class="position-absolute" style="left: 40px; transform: rotate(-8deg) translateY(20px); z-index: 1; opacity: 0.7;">
                        <a href="#" class="d-block rounded-3 overflow-hidden shadow" style="width: 160px; height: 230px;">
                            <div class="w-100 h-100 d-flex align-items-center justify-content-center" style="background: linear-gradient(135deg, #334155, #1e293b);">
                                <i class="bi bi-book fs-1" style="color: #64748b;"></i>
                            </div>
                        </a>
                    </div>

                    <!-- Center featured book -->
                    <div class="position-relative" style="z-index: 3;">
                        <a href="#" class="d-block">
                            <div class="rounded-3 overflow-hidden shadow-lg" style="width: 240px; height: 340px;">
                                <div class="w-100 h-100 d-flex align-items-center justify-content-center" style="background: linear-gradient(135deg, #334155, #1e293b);">
                                    <i class="bi bi-book display-1" style="color: #64748b;"></i>
                                </div>
                            </div>
                        </a>
                        <!-- Save badge -->
                        <div class="position-absolute top-0 end-0 rounded-3 shadow px-3 py-2" style="transform: translate(20px, -12px); z-index: 10; background: rgba(255,255,255,0.95);">
                            <small class="text-uppercase fw-medium" style="font-size: 0.6rem; color: #64748b;">Save up to</small>
                            <span class="fw-bold fs-5 ms-1" style="color: #17A34A;">50%</span>
                        </div>
                    </div>

                    <!-- Back-right book -->
                    <div class="position-absolute" style="right: 40px; transform: rotate(8deg) translateY(20px); z-index: 1; opacity: 0.7;">
                        <a href="#" class="d-block rounded-3 overflow-hidden shadow" style="width: 160px; height: 230px;">
                            <div class="w-100 h-100 d-flex align-items-center justify-content-center" style="background: linear-gradient(135deg, #334155, #1e293b);">
                                <i class="bi bi-book fs-1" style="color: #64748b;"></i>
                            </div>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="position-absolute bottom-0 start-0 end-0" style="line-height: 0;">
        <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="width: 100%; height: 40px;">
            <path d="M0,60 L0,20 Q360,0 720,30 Q1080,60 1440,10 L1440,60 Z" fill="#f5f5f5"></path>
        </svg>
    </div>
</section>

