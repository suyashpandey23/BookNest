
@model IEnumerable<Product>
<partial name="_Hero" />

<div class="container py-5" id="catalog">
    <div class="mb-4">
        <h2 class="fw-bold mb-1">Our Collection</h2>
        <p class="text-secondary mb-0">Explore all @Model.Count() books in our catalog</p>
    </div>

    <!-- Books Grid -->
    @if (Model.Any())
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">

            @foreach (var product in Model)
            {
                <div class="col">
                    <div class="card h-100 border shadow-sm book-card">
                        <a asp-action="Details" asp-route-productId="@product.Id" class="text-decoration-none">
                            <div style="aspect-ratio: 3/4; overflow: hidden;">
                                @if (!string.IsNullOrEmpty(product.ImageUrl))
                                {
                                    <img src="@Url.Content(product.ImageUrl)" class="w-100 h-100" style="object-fit: cover;"/>
                                }
                                else
                                {


                                    <div class="w-100 h-100 d-flex align-items-center justify-content-center bg-light">
                                        <i class="bi bi-book display-3 text-secondary"></i>
                                    </div>
                                }
                            </div>
                        </a>
                        <div class="card-body">
                           
                            <span class="badge bg-secondary mb-2">@product.Category.Name</span>
                            <h6 class="card-title fw-semibold mb-2" style="min-height: 2.5rem;">
                                <a href="#" class="text-decoration-none text-dark">
                                    @product.Title
                                </a>
                            </h6>
                            <p class="text-secondary small mb-2">by @product.Author</p>
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <span class="fw-bold text-success">@product.Price100.ToString("c")</span>
                                    @if (product.ListPrice > product.Price100)
                                    {
                                        <small class="text-decoration-line-through text-muted ms-1">@product.ListPrice.ToString("c")</small>
                                    }
                                </div>
                                <a asp-action="Details" asp-route-productId="@product.Id" class="btn btn-sm btn-outline-dark">
                                    View
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }

        </div>
    }
</div>
<partial name="_Newsletter" />